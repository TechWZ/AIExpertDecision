# === Combined .gitignore ===
# This file merges the .gitignore from the project root and frontend/
# All paths are relative to the project root (ai-expert-simulator/)

# Python related
__pycache__/
*.py[cod]
*$py.class

# Virtual environment (backend specific)
/backend/venv/

# Environment variables
.env
*.env.*
!.env.example

# IDE / Editor / OS specific (Global)
.idea/      # Ignores all .idea directories
*.swp       # Swap files
*~          # Backup files
.DS_Store   # macOS
Thumbs.db   # Windows

# VSCode specific (Root directory)
# This was in the root .gitignore, ensure it's distinct from frontend/.vscode
.vscode/*
!.vscode/extensions.json

# --- Frontend Specific ---
# Rules originally from frontend/.gitignore, now prefixed with 'frontend/'

# Frontend Node modules & build artifacts
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# Frontend Logs
frontend/logs/
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Frontend Editor/IDE specific files
# Note: .vscode rules from frontend/.gitignore are now specific to frontend/.vscode/
frontend/.vscode/*
!frontend/.vscode/extensions.json

# Other frontend specific ignores
frontend/*.local
frontend/*.suo
frontend/*.ntvs*
frontend/*.njsproj
frontend/*.sln
frontend/*.sw? # e.g., *.swa, *.swb (distinct from global *.swp)

# --- Root-level specific log files ---
# These were in the original root .gitignore.
# Kept for logs specifically at the project root, if not covered by frontend/ patterns.
# Note: some of these might be duplicates of prefixed frontend logs, but it's safer to keep them.
npm-debug.log
yarn-error.log
pnpm-debug.log